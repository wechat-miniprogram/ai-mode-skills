# wxa-skills-eval 环境变量（完整清单见 references/configuration.md）

# ── 必填：LLM 服务配置 ───────────────────────────────────────────────
WXA_SKILL_EVAL_LLM_BASE_URL=https://api.openai.com/v1
WXA_SKILL_EVAL_LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
WXA_SKILL_EVAL_LLM_MODEL=gpt-4o

# ── 可选：LLM 客户端调优 ─────────────────────────────────────────────
# WXA_SKILL_EVAL_LLM_TIMEOUT=60
# WXA_SKILL_EVAL_LLM_MAX_RETRIES=3
# LLM 全局并发上限（正整数，默认 3）
# WXA_SKILL_EVAL_LLM_CONCURRENCY=3
# LLM 是否使用流式接口（开发者对接的 LLM 仅暴露 stream 接口时启用，1/true 启用，默认 0）
# WXA_SKILL_EVAL_LLM_STREAM=0

# ── 可选：节点行为调优（调小加快调试迭代）───────────────────────────
# gen_trajectory 最大对话轮数
# WXA_SKILL_EVAL_MAX_TRAJECTORY_ROUNDS=12
# explore 每个 skill 生成的探索轨迹条数
# WXA_SKILL_EVAL_EXPLORE_N_TRAJECTORIES=3
# explore 每条轨迹最多工具调用次数（至少 3 才能通过合法性校验）
# WXA_SKILL_EVAL_EXPLORE_MAX_STEPS=10

# ── 可选：DevTools 适配器 ────────────────────────────────────────────
# 新版微信开发者工具（macOS .pkg / Windows 安装包）安装后会注册 wechatidecli 环境变量，
# 评测工具会自动探测该命令并优先使用，无需手动配置路径。
#
# 若未检测到 wechatidecli（旧版开发者工具），则回退到以下手动配置：
# 微信开发者工具安装路径（不配置时按平台默认探测）
#   macOS  示例：DEVTOOLS_ENV_APP_PATH=/Applications/wechatwebdevtools.app
#   Windows 示例：DEVTOOLS_ENV_APP_PATH=C:\Program Files (x86)\Tencent\微信web开发者工具
#   （Windows 也可填 微信开发者工具.exe 文件路径，会自动取所在目录；校验依据是该目录下存在 cli.bat）
# DEVTOOLS_ENV_APP_PATH=/Applications/wechatwebdevtools.app
# DEVTOOLS_ENV_PROJECT_PATH=/absolute/path/to/miniprogram
# DEVTOOLS_ENV_CALL_TOOL_TIMEOUT=25
# DEVTOOLS_ENV_CHAT_TIMEOUT=50
# DEVTOOLS_ENV_LAUNCH_TIMEOUT=15
# DEVTOOLS_ENV_SKIP_AUTO_LAUNCH=1

# 仅本地开发调试用：强制覆盖最终 CLI 路径（优先级最高，会跳过 wechatidecli / appPath 探测）
# 配置错误时会在启动校验阶段立即报错。
# DEVTOOLS_CLI_OVERRIDE=/path/to/your/cli

# ── 调试 ─────────────────────────────────────────────────────────────
# WXA_SKILL_EVAL_DEBUG=1
